  {
    "id": "scroll-scale-reveal",
    "title": "Scroll scale reveal (clip + zoom on enter)",
    "category": "pictures",
    "target": [
      "image",
      "section"
    ],
    "trigger": [
      "scroll"
    ],
    "type": [
      "reveal",
      "parallax"
    ],
    "tags": [
      "clip-path",
      "scale",
      "scroll-progress",
      "scrub",
      "inset",
      "expo-out"
    ],
    "description": "The landonorris.com media entrance: as a block scrolls up into view its clip-path inset opens from a narrow slit to full frame while the inner image eases down from an overscale, so the picture seems to 'unmask' and settle. Scrubbed to scroll progress (not a one-shot) so it tracks the scrollbar.",
    "source": {
      "name": "landonorris.com",
      "verified": false
    },
    "params": {
      "clip": "inset(18% 8% round 8px) -> inset(0% 0% round 8px)",
      "scale": "1.25 -> 1.0 on the inner image",
      "ease": "applied as eased progress (expo-out feel)",
      "range": "bottom 90% -> center"
    },
    "a11y": "prefers-reduced-motion: fully revealed, no clip/scale.",
    "createdAt": "2026-06-14",
    "path": "effects/pictures/scroll-scale-reveal",
    "demo": "effects/pictures/scroll-scale-reveal/demo.html",
    "stacks": [
      "vanilla"
    ],
    "files": [
      "demo.html",
      "vanilla.css",
      "vanilla.js"
    ]
  },
  {
    "id": "scroll-pin",
    "title": "Pinned scroll section (sticky + horizontal track)",
    "category": "sections",
    "target": [
      "section"
    ],
    "trigger": [
      "scroll"
    ],
    "type": [
      "parallax",
      "state-change"
    ],
    "tags": [
      "pin",
      "sticky",
      "horizontal-scroll",
      "scroll-progress",
      "scrub",
      "chapters"
    ],
    "description": "The landonorris.com chapter move: a section pins to the viewport (position:sticky) while a tall outer track scrolls past, and that scroll distance is mapped to a horizontal translate of an inner row — so vertical scrolling scrubs through panels left-to-right. Progress also drives a thin progress bar. CSS sticky does the pin; JS only maps progress to transform.",
    "source": {
      "name": "landonorris.com",
      "verified": false
    },
    "params": {
      "pinHeight": "outer track = (panels) * 100vh",
      "ease": "linear scrub (tied to scroll)",
      "travel": "x = -progress * (trackWidth - viewportWidth)"
    },
    "a11y": "prefers-reduced-motion: track unpins and panels stack vertically (native scroll).",
    "createdAt": "2026-06-14",
    "path": "effects/sections/scroll-pin",
    "demo": "effects/sections/scroll-pin/demo.html",
    "stacks": [
      "vanilla"
    ],
    "files": [
      "demo.html",
      "vanilla.css",
      "vanilla.js"
    ]
  },
